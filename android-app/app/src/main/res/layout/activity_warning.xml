<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFF1F2"
    android:padding="28dp">

    <!-- Card Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/love_dialog_background"
        android:padding="30dp"
        android:elevation="4dp">

        <!-- Broken Heart Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💔"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protection Disabled! ❌"
            android:textColor="#BE123C"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Administrator permissions have been turned off.\n\nTo protect your phone and ensure anti-theft services remain active, you must re-enable Device Admin permissions immediately."
            android:textColor="#881337"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.25"
            android:layout_marginBottom="28dp" />

        <!-- Activation Button -->
        <Button
            android:id="@+id/btn_re_enable_admin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Device Admin 🔒"
            android:background="@drawable/button_background"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="2dp" />

    </LinearLayout>
</LinearLayout>
