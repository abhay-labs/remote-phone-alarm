<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#D9FFF1F2"
    android:padding="24dp">

    <!-- Card Container -->
    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/love_dialog_background"
        android:padding="24dp"
        android:elevation="4dp">

        <!-- Heart Emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💖"
            android:textSize="56sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify Your Love! 🔒"
            android:textColor="#BE123C"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To deactivate or uninstall this app, please enter your hubby/love's correct name: \n\n(Hint: mylove...) 🌸"
            android:textColor="#881337"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="20dp" />

        <!-- Input Field -->
        <EditText
            android:id="@+id/et_hubby_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_background"
            android:textColor="#881337"
            android:padding="14dp"
            android:inputType="text"
            android:hint="Type name here... 💖"
            android:textColorHint="#FDA4AF"
            android:textSize="14sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Confirm Button -->
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Deactivate &amp; Uninstall 💔"
            android:background="@drawable/button_background"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="2dp"
            android:layout_marginBottom="12dp" />

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cancel 🌸"
            android:background="@android:color/transparent"
            android:textColor="#F43F5E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>
</LinearLayout>
