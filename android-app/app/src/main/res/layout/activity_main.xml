<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GuardianLink Alarm Client"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Background Alarm Listener System"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="25dp"/>

        <!-- Section: Connection & Identity Config -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REGISTRATION &amp; CONNECTION"
                android:textColor="#A5B4FC"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Backend API URL:"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/backend_url_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E2E2E"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:inputType="textUri"
                android:hint="https://your-app.onrender.com"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Email Address:"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E2E2E"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:inputType="textEmailAddress"
                android:hint="user@example.com"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Security Token:"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/admin_token_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E2E2E"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:inputType="textPassword"
                android:hint="Enter security token"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/save_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save &amp; Connect"
                android:backgroundTint="#6366F1"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"/>
        </LinearLayout>

        <!-- Section: Permission Manager -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM PERMISSIONS"
                android:textColor="#A5B4FC"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/permission_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Checking permissions..."
                android:textColor="#FFA500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/request_dnd_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Do Not Disturb Policy"
                android:backgroundTint="#4B5563"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"/>
        </LinearLayout>

        <!-- Section: Big Stop Button -->
        <Button
            android:id="@+id/stop_alarm_btn"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="STOP ALARM"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#E11D48"
            android:textColor="#FFFFFF"
            android:elevation="4dp"
            android:textAllCaps="true"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* Ensure Do Not Disturb access is enabled so the app can override silent profiles."
            android:textColor="#555555"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

    </LinearLayout>
</ScrollView>
