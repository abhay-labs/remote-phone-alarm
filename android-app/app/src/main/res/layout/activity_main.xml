<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1F2"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header Title Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑"
                android:textSize="45sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Princess Guardian"
                android:textColor="#BE123C"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Always Protected 💖"
                android:textColor="#F43F5E"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Section: Connection Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REGISTER CONNECTION 🎁"
                android:textColor="#E11D48"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Email Address:"
                android:textColor="#4C0519"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_background"
                android:textColor="#881337"
                android:padding="14dp"
                android:inputType="textEmailAddress"
                android:hint="princess@example.com"
                android:textColorHint="#FDA4AF"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/save_btn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Save &amp; Connect ✨"
                android:background="@drawable/button_background"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:elevation="1dp"/>
        </LinearLayout>

        <!-- Section: System Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="25dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM STATUS 🎀"
                android:textColor="#E11D48"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/permission_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Checking permissions..."
                android:textColor="#D97706"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Hidden input fields to prevent code breakages in MainActivity -->
        <EditText
            android:id="@+id/backend_url_input"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/admin_token_input"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Hidden buttons to prevent code breakages in MainActivity -->
        <Button
            android:id="@+id/request_dnd_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/stop_alarm_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* This app runs silently in the background. Control siren triggering and location mapping entirely from the web panel."
            android:textColor="#BE123C"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

    </LinearLayout>
</ScrollView>
